{#-
Workflow template. Regenerate the workflow using the ./update script.
-#}

# Do not edit this file. It is generated from dotnet.yml.j2.

on:
  push:
    branches:
    - main
    tags:
    - 'v*'
  workflow_run:
    workflows: ["toolchain"]
    types: [completed]

permissions:
  packages: read
  actions: read
  checks: write
  contents: write

{#-
TODO: aspnetcore build fails on x64 with:
EXEC : error : Failed to load assembly 'System.Private.CoreLib'
-#}
{%- set arches = ['ppc64le', 's390x'] %}

{%- set projects = ['sdk'] %}

{%- set matrix -%}
    strategy:
      matrix:
        arch: [{{ ', '.join(arches) }}]
        isV6:
        - {% raw %}${{ startsWith(github.ref, 'refs/tags/v6.') }}{% endraw %}
        exclude:
        - arch: ppc64le
          isV6: true
{%- endset %}

{%- set image -%}ghcr.io/ibm/dotnet-{% raw %}${{ matrix.arch }}{% endraw %}-toolchain:latest{%- endset %}

{%- set init_steps -%}
    - name: Show free disk space
      run: df -h
    - name: Free some disk space
      run: rm -r /opt/hostedtoolcache
    - name: Show free disk space
      run: df -h
    - name: Configure git
      run: git config --global user.email iii@linux.ibm.com &&
           git config --global user.name "dotnet-s390x bot"
    - name: Checkout dotnet-s390x
      uses: actions/checkout@v4
      with:
        repository: {% raw %}${{ github.event.workflow_run.head_repository.full_name || github.repository }}{% endraw %}
        ref: {% raw %}${{ github.event.workflow_run.head_sha || github.sha }}{% endraw %}
    - name: Login to GitHub Container Registry
      uses: docker/login-action@v3
      with:
        registry: ghcr.io
        username: {% raw %}${{ github.actor }}{% endraw %}
        password: {% raw %}${{ secrets.GITHUB_TOKEN }}{% endraw %}
{%- endset %}

jobs:
{%- for i in range(projects | length) %}
  {{ projects[i] }}:
    {%- if i != 0 %}
    needs: {{ projects[i - 1] }}
    {%- endif %}
    if: {% raw %}${{ github.event_name == 'push' || (github.event_name == 'workflow_run' && github.event.workflow_run.event == 'pull_request' && github.event.workflow_run.conclusion == 'success') }}{% endraw %}
    runs-on: ubuntu-latest
    {{ matrix }}
    steps:
    - name: Create check run
      if: {% raw %}${{ github.event_name == 'workflow_run' }}{% endraw %}
      id: check
      uses: actions/github-script@v7
      with:
        script: |
          const { data } = await github.rest.checks.create({
            owner: context.repo.owner,
            repo: context.repo.repo,
            name: '{{ projects[i] }} ({% raw %}${{ matrix.arch }}, ${{ matrix.isV6 }}{% endraw %})',
            head_sha: '{% raw %}${{ github.event.workflow_run.head_sha }}{% endraw %}',
            status: 'in_progress',
            details_url: `${context.serverUrl}/${context.repo.owner}/${context.repo.repo}/actions/runs/${context.runId}`,
          });
          return data.id;
    {{ init_steps }}
    {%- if i != 0 %}
    - name: Download the previous stage's artifacts
      uses: actions/download-artifact@v4
      with:
        name: {{ projects[i - 1] }}-{% raw %}${{ matrix.arch }}{% endraw %}
    {%- endif %}
    - name: Install quilt
      run: |
        sudo apt-get update
        sudo apt-get install -y quilt
    - name: Prepare
      run: ./dotnet-prepare
    - name: Download toolchain image artifact
      if: {% raw %}${{ github.event_name == 'workflow_run' }}{% endraw %}
      uses: actions/download-artifact@v4
      with:
        name: toolchain-image-{% raw %}${{ matrix.arch }}{% endraw %}
        github-token: {% raw %}${{ secrets.GITHUB_TOKEN }}{% endraw %}
        run-id: {% raw %}${{ github.event.workflow_run.id }}{% endraw %}
    - name: Load toolchain image
      if: {% raw %}${{ github.event_name == 'workflow_run' }}{% endraw %}
      run: docker load -i toolchain-image.tar
    - name: Build
      run: ARCH={% raw %}${{ matrix.arch }}{% endraw %} ./docker/run-image {{ image }} ./dotnet-build
    - name: Upload the intermediate results
      uses: actions/upload-artifact@v4
      with:
        name: {{ projects[i] }}-{% raw %}${{ matrix.arch }}{% endraw %}
        path: |
          local-downloads/
          local-packages/
          output/
    - name: Update check run
      if: {% raw %}${{ always() && github.event_name == 'workflow_run' }}{% endraw %}
      uses: actions/github-script@v7
      with:
        script: |
          await github.rest.checks.update({
            owner: context.repo.owner,
            repo: context.repo.repo,
            check_run_id: {% raw %}${{ steps.check.outputs.result }}{% endraw %},
            status: 'completed',
            conclusion: '{% raw %}${{ job.status }}{% endraw %}',
          });
{%- endfor %}
  release:
    needs: sdk
    runs-on: ubuntu-latest
    strategy:
      matrix:
        arch: [x64]
    if: {% raw %}${{ github.event_name == 'push' && github.ref_type == 'tag' }}{% endraw %}
    steps:
    {{ init_steps }}
    {%- for arch in arches %}
    - name: Download the {{ arch }} sdk artifacts
      uses: actions/download-artifact@v4
      with:
        name: sdk-{{ arch }}
    {%- if arch == 'ppc64le' %}
      if: {% raw %}${{ !startsWith(github.ref, 'refs/tags/v6.') }}{% endraw %}
    {%- endif %}
    {%- endfor %}
    - name: Create a release
      run: gh release create --notes "" "{% raw %}${{ github.ref_name }}{% endraw %}" output/*
      env:
        GH_TOKEN: {% raw %}${{ secrets.GITHUB_TOKEN }}{% endraw %}
